---
import {Icon} from "astro-icon/components"

interface Props {
    link: string
}

const { link }  = Astro.props;
---
<a href={link} class="inline-block ml-60">
    <div class="group border flex gap-2  border-dark rounded w-[175px] h-[50px] hover:border-soft-white ">
        <p class="font-extralight text-xl leading-7 group-hover:text-soft-white p-3">View Code  </p>
        <Icon size="40" class="text-dark group-hover:text-soft-white mt-1" name="fa7-brands:github"></Icon>
    </div>
</a>
