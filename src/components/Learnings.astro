---
interface Props {
    learnings: string[];
}
const { learnings } = Astro.props;
---
<section class="my-12 border-l border-[#a0f000]/40 py-1 pl-6">
    <h2 class="mb-4 text-sm font-light uppercase tracking-[0.2em] text-[#a0f000]">Learnings</h2>
    <ul class="ml-0 flex flex-col gap-2">
        {learnings.map((item) => (
            <li class="list-none text-[1.1rem] leading-7 text-gray-400 before:mr-2 before:text-dark before:content-['–']">
                {item}
            </li>
        ))}
    </ul>
</section>
